{
  "name": "cubescript",
  "version": "0.1.0",
  "description": "Cubescript — block-flavored language for mod-minded tooling (LMU CMSI 3802)",
  "type": "module",
  "author": "Mason Lui, Leila Nawas, Aidan Hodges, Paige Inoue, Cooper Clausen",
  "license": "MIT",
  "repository": {
    "type": "module",
    "url": "https://github.com/MasonLui/CubeScript.git"
  },
  "keywords": [
    "compiler",
    "ohm",
    "cubescript",
    "minecraft",
    "cmsi-3802"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "cubescript": "src/cubescript.js"
  },
  "scripts": {
    "test": "c8 node --test test/*.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ohm-js": "^17.1.0"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "prettier": "^3.5.3"
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "all": true,
    "include": [
      "src/**/*.js"
    ]
  }
}
